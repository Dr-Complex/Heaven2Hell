; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="demo-for-[???]"
config/description="IDK what to do..."
config/tags=PackedStringArray("2d", "game")
run/main_scene="res://main/Scenes/managers/master_module.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
boot_splash/bg_color=Color(0.5, 0.5, 0.5, 1)
boot_splash/stretch_mode=4
boot_splash/image="uid://dwl7hf3n2ygac"
config/icon="uid://1c4n0fp6wup"

[autoload]

Spawning="*uid://gixop20d1d75"

[display]

window/size/viewport_width=1000
window/size/viewport_height=625
window/size/initial_position_type=4

[editor]

naming/scene_name_casing=1
naming/script_name_casing=1
version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/AsepriteWizard/plugin.cfg", "res://addons/BulletUpHell/plugin.cfg", "res://addons/GDQuest_GDScript_formatter/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "orange",
"res://main/Recources/": "gray"
}

[global_group]

Players="The main player"
Enemies="The enemies of the game "

